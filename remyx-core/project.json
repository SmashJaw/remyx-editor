{
  "name": "remyx-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/remyx-core/src",
  "projectType": "library",
  "tags": ["scope:core"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "packages/remyx-core"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build --watch",
        "cwd": "packages/remyx-core"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint packages/remyx-core/src"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --selectProjects remyx-core"
      }
    },
    "analyze": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ANALYZE=true vite build",
        "cwd": "packages/remyx-core"
      }
    }
  }
}
